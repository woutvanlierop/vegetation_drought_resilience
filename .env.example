# OpenEO Backend Configuration
# Supports multiple backends: EODC, Sentinel Hub, CDSE (Copernicus), etc.
# See: https://openeo.cloud/
OPENEO_BACKEND_URL=https://openeo.creo.vito.be/openeo/1.1.0
OPENEO_BACKEND_NAME=Vito
OPENEO_USERNAME=your-eodc-username
OPENEO_PASSWORD=your-eodc-password
OPENEO_SENTINEL2_COLLECTION_ID=SENTINEL2_L2A
OPENEO_ERA5_COLLECTION_ID=ERA5
OPENEO_AUTH_METHOD=auto
OPENEO_CLIENT_ID=
OPENEO_CLIENT_SECRET=
OPENEO_AUTH_PROVIDER_ID=

# Alternative: CDSE (Copernicus Data Space Ecosystem) - free tier
# OPENEO_BACKEND_URL=https://openeo.dataspace.copernicus.eu
# OPENEO_USERNAME=your-cdse-username
# OPENEO_PASSWORD=your-cdse-password
# If your backend does not support basic auth, use client credentials:
# OPENEO_AUTH_METHOD=client_credentials
# OPENEO_CLIENT_ID=your-client-id
# OPENEO_CLIENT_SECRET=your-client-secret
# OPENEO_AUTH_PROVIDER_ID=your-provider-id

# PostgreSQL + PostGIS Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=drought_user
DB_PASSWORD=your_secure_password
DB_NAME=drought_database
DB_SSLMODE=disable

# Region of Interest (Flanders, Belgium bounds)
ROI_NAME=flanders
ROI_NORTH=51.507
ROI_SOUTH=50.674
ROI_EAST=5.918
ROI_WEST=2.754

# Data Processing
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
REFERENCE_DATA_DIR=./data/reference

# Feature Engineering
BASELINE_START_YEAR=2016
BASELINE_END_YEAR=2022
TARGET_RESOLUTION_METERS=100

# Drought Index Parameters
DROUGHT_WINDOW_MONTHS=1
SPI_WEIGHT=0.35
VSI_WEIGHT=0.35
SM_WEIGHT=0.30
CONFIDENCE_THRESHOLD=0.6

# Sentinel-2 Parameters
SENTINEL2_MAX_CLOUD_COVER=20
SENTINEL2_BANDS=B02,B03,B04,B05,B06,B07,B08,B8A,B11,B12,SCL

# ERA5 Parameters (via OpenEO)
ERA5_VARIABLES=temperature_2m,total_precipitation_sum,volumetric_soil_water_layer_1,volumetric_soil_water_layer_2

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/drought_monitoring.log

# Streamlit Dashboard
STREAMLIT_THEME=light
STREAMLIT_MAP_CENTER_LAT=51.1
STREAMLIT_MAP_CENTER_LNG=4.4
STREAMLIT_MAP_ZOOM=8
